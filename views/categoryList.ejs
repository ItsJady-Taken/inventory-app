<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h1>Inventory Categories</h1>
    
    <% if (categories.length===0) { %>
        <h3>Empty</h3>
        <% } else { %>
            <ul>
                <% categories.forEach(category=> { %>
                    <li>
                        <%= category.name %>
                    </li>
                    <% }); %>
            </ul>
            <% } %>
    
    <a href="/categories/new">Add New Category</a>
    
</body>
</html>